# Platform Master Service Configuration Example
# Скопируйте этот файл в .env и заполните актуальными значениями

# Database configuration
DATABASE_URL=sqlite:///./master.db

# Authentication provider: builtin | keycloak
AUTH_PROVIDER=builtin

# Application environment
APP_ENV=prod

# Platform domain (used for Caddy routing)
PLATFORM_DOMAIN=localhost

# Paths
SERVICES_PATH=/services
CADDY_CONFIG_PATH=/caddy
BACKUP_PATH=/backups

# Keycloak settings (только если AUTH_PROVIDER=keycloak)
KEYCLOAK_SERVER_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=platform
KEYCLOAK_CLIENT_ID=master-service

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_IDS=[]
