{
    email admin@urfu.online
    admin 0.0.0.0:2019
    
    # Автоматический HTTPS в зависимости от окружения
    # В продакшене - автоматические SSL-сертификаты и редиректы (по умолчанию)
    # В разработке - отключаем редиректы и сертификаты для локальных доменов
    import /etc/caddy/snippets/auto_https_dev.caddy if {env.APP_ENV} eq "dev"

    # Access log (по умолчанию)
    log {
        output file /var/log/caddy/access.log
        format json
        level INFO
    }

    # Debug log (именованный)
    log debug {
        output file /var/log/caddy/debug.log
        format json
        level DEBUG
    }
}
 
# Импорт глобальных сниппетов
import /etc/caddy/snippets/*.caddy

# Импорт конфигураций разработки только в dev-окружении
import /etc/caddy/conf.d/development.caddy if {env.APP_ENV} eq "dev"

# Импорт всех конфигураций сервисов (домены, порты)
import /etc/caddy/conf.d/*.caddy